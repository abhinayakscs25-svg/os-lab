#include <stdio.h>

int main() {
    int n, i, completed = 0, current_time = 0, shortest;

    printf("Enter number of processes: ");
    scanf("%d", &n);

    int at[n], bt[n], ct[n], tat[n], wt[n], visited[n];

    printf("Enter Arrival Time and Burst Time:\n");
    for(i = 0; i < n; i++) {
        printf("P%d AT BT: ", i+1);
        scanf("%d %d", &at[i], &bt[i]);
        visited[i] = 0;   // Mark all processes as not completed
    }

    while(completed < n) {
        shortest = -1;

        // Find shortest job among arrived processes
        for(i = 0; i < n; i++) {
            if(at[i] <= current_time && visited[i] == 0) {
                if(shortest == -1 || bt[i] < bt[shortest]) {
                    shortest = i;
                }
            }
        }

        if(shortest == -1) {
            current_time++;   // If no process has arrived, move time forward
        } else {
            current_time += bt[shortest];
            ct[shortest] = current_time;
            visited[shortest] = 1;
            completed++;
        }
    }

    // Calculate TAT and WT
    for(i = 0; i < n; i++) {
        tat[i] = ct[i] - at[i];
        wt[i] = tat[i] - bt[i];
    }

    // Display Results
    printf("\nProcess\tAT\tBT\tCT\tTAT\tWT\n");
    for(i = 0; i < n; i++) {
        printf("P%d\t%d\t%d\t%d\t%d\t%d\n",
               i+1, at[i], bt[i], ct[i], tat[i], wt[i]);
    }

    return 0;
}
